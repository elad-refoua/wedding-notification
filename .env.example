# Local development only. Production uses Google Secret Manager + Cloud Run env vars.
# See docs/DEPLOYMENT.md for production.

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=        # SMS sender (real US number, e.g. +16562554592)
TWILIO_WHATSAPP_NUMBER=     # WhatsApp sandbox number (+14155238886) or approved WABA sender

# --- Auth ---
DASHBOARD_TOKEN=wedding-admin-2026

# --- AI ---
GEMINI_API_KEY=             # Gemini 2.0 Flash — Level 3 reply parser fallback

# --- Server ---
PORT=3860                   # Cloud Run overrides this to 8080
TZ=Asia/Jerusalem
WEBHOOK_BASE_URL=           # Your public URL for Twilio statusCallback URLs
                            # Production: https://wedding-notification-246665220680.europe-west1.run.app

# --- Database (usually leave unset for local dev) ---
# DB_PATH=./guests.db       # Defaults to ./guests.db locally; set to /data/guests.db on Cloud Run
# DB_JOURNAL_MODE=WAL       # Defaults to WAL (fast local). On Cloud Run use DELETE (GCS FUSE cannot mmap).
